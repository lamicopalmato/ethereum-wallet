# ─────────────────────────────────────────────────────────────────────────────
# Deploy mode
# Must match the --profile you pass to docker compose.
#   local  → runs a self-hosted geth node (requires ~500 GB NVMe SSD)
#   public → uses a remote JSON-RPC endpoint (no SSD required, rate-limited)
# ─────────────────────────────────────────────────────────────────────────────
DEPLOY_MODE=local

# ─────────────────────────────────────────────────────────────────────────────
# Ethereum node URL
# Set to the appropriate URL for your deploy mode (see below).
# ─────────────────────────────────────────────────────────────────────────────

# Used when DEPLOY_MODE=local. Points to the geth service inside the compose network.
LOCAL_ETH_NODE_URL=http://geth:8545

# Used when DEPLOY_MODE=public. Any JSON-RPC endpoint reachable from the wallet container.
# Default: publicnode.com (no API key required).
PUBLIC_ETH_NODE_URL=https://ethereum-rpc.publicnode.com

# Example alternatives for PUBLIC_ETH_NODE_URL:
# PUBLIC_ETH_NODE_URL=https://eth-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
# PUBLIC_ETH_NODE_URL=https://mainnet.infura.io/v3/<YOUR_API_KEY>
# PUBLIC_ETH_NODE_URL=https://ethereum-rpc.publicnode.com

# ETH_NODE_URL is what the wallet container actually reads.
# Leave it unset (or set to LOCAL_ETH_NODE_URL) for local mode.
# Set it to your public endpoint when using public mode:
#   ETH_NODE_URL=https://ethereum-rpc.publicnode.com
ETH_NODE_URL=http://geth:8545

# ─────────────────────────────────────────────────────────────────────────────
# Throughput tuning
#
# LOCAL mode (geth node via HTTP/IPC — high throughput):
BATCH_SIZE=500
RPC_CONCURRENCY=32

# PUBLIC mode (publicnode.com has a batch limit of ~100 and strict rate limits).
# Uncomment these two lines and comment out the LOCAL defaults above when using
# DEPLOY_MODE=public:
# BATCH_SIZE=100
# RPC_CONCURRENCY=4

# Number of goroutines generating key pairs. 0 = runtime.NumCPU()
# KEYGEN_WORKERS=0

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=Ethereum
MYSQL_USER=app
MYSQL_PASSWORD=app

# ─────────────────────────────────────────────────────────────────────────────
# Ports
# ─────────────────────────────────────────────────────────────────────────────
WALLET_PORT=8080
HOMEPAGE_PORT=3000
GETH_HTTP_PORT=8545
GETH_WS_PORT=8546

# ─────────────────────────────────────────────────────────────────────────────
# Deploy mode — informational only (matches the --profile flag passed to docker
# compose). The app does not read this variable at runtime.
#   local  → runs a self-hosted geth node (requires ~500 GB NVMe SSD)
#   public → uses a remote JSON-RPC endpoint (no SSD required, rate-limited)
# ─────────────────────────────────────────────────────────────────────────────
DEPLOY_MODE=local

# ─────────────────────────────────────────────────────────────────────────────
# Ethereum node URL — the wallet container reads this variable.
#
# LOCAL mode (DEPLOY_MODE=local):
#   ETH_NODE_URL=http://geth:8545
#
# PUBLIC mode (DEPLOY_MODE=public) — uncomment your preferred endpoint:
#   ETH_NODE_URL=https://ethereum-rpc.publicnode.com
#   ETH_NODE_URL=https://eth-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
#   ETH_NODE_URL=https://mainnet.infura.io/v3/<YOUR_API_KEY>
# ─────────────────────────────────────────────────────────────────────────────
ETH_NODE_URL=http://geth:8545

# ─────────────────────────────────────────────────────────────────────────────
# Throughput tuning
#
# LOCAL mode — high throughput via local node:
BATCH_SIZE=500
RPC_CONCURRENCY=32

# PUBLIC mode — publicnode.com has a batch limit of ~100 and strict rate limits.
# Uncomment and replace the LOCAL defaults above when using DEPLOY_MODE=public:
# BATCH_SIZE=100
# RPC_CONCURRENCY=4

# Number of goroutines generating key pairs. 0 = runtime.NumCPU()
# KEYGEN_WORKERS=0

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=Ethereum
MYSQL_USER=app
MYSQL_PASSWORD=app

# ─────────────────────────────────────────────────────────────────────────────
# Ports
# ─────────────────────────────────────────────────────────────────────────────
WALLET_PORT=8080
HOMEPAGE_PORT=3000
GETH_HTTP_PORT=8545
GETH_WS_PORT=8546
